{
  "name": "ijbnet",
  "version": "v0.9.4",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @ijbnet/backend --filter @ijbnet/frontend dev",
    "build": "pnpm --filter @ijbnet/shared build && pnpm --filter @ijbnet/backend --filter @ijbnet/frontend build",
    "lint": "pnpm --recursive lint",
    "migrate": "pnpm --filter backend migrate",
    "migrate:undo": "pnpm --filter backend migrate:undo",
    "seed": "pnpm --filter backend seed",
    "seed:undo": "pnpm --filter backend seed:undo",
    "version:bump": "node -e \"const fs=require('fs'),v=process.argv[1];['package.json','apps/frontend/package.json','apps/backend/package.json'].forEach(f=>{const p=JSON.parse(fs.readFileSync(f,'utf8'));p.version=v;fs.writeFileSync(f,JSON.stringify(p,null,2)+'\\n');});console.log('Bumped to '+v);\""
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
