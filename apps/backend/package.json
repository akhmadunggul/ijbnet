    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.3.1",
    "file-type": "^19.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.7",
    "nodemailer": "^6.9.13",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
